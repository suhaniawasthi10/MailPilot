PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ai-chief-of-staff?retryWrites=true&w=majority
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback
JWT_SECRET=your_jwt_secret_here
FRONTEND_URL=http://localhost:5173
GROQ_API_KEY=gsk_your_groq_api_key_here
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_REDIRECT_URI=http://localhost:5000/auth/microsoft/callback
TOKEN_ENCRYPTION_KEY=your_32_char_hex_encryption_key_here

# --- Webhook / Real-time Sync ---
# Google Cloud Pub/Sub topic for Gmail push notifications
# Format: projects/<project-id>/topics/<topic-name>
# Setup: Create topic in GCP Console, grant gmail-api-push@system.gserviceaccount.com Publisher role
GOOGLE_PUBSUB_TOPIC=projects/your-gcp-project/topics/gmail-notifications

# Public URL of your backend (used for Microsoft webhook callback)
# In production: https://your-app.railway.app
# In development: use ngrok (e.g., https://abc123.ngrok.io)
WEBHOOK_BASE_URL=https://your-public-url.com

# Secret string to verify Microsoft webhook notifications are genuine
MICROSOFT_WEBHOOK_SECRET=your_random_secret_string_here
